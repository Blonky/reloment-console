# Reloment Console — environment.
# With NEITHER of these set, the console runs in deterministic demo mode
# (in-memory Hartley Insurance Group book). Set both to talk to a live platform.

# Base URL of the platform API. Its presence switches createClient() to HttpClient.
# VITE_API_URL=https://your-platform-host

# Tenant UUID, sent as the x-tenant-id header on every request.
# NOTE: this is only used when the platform runs with AUTH_REQUIRED=false (dev/demo).
# A real install runs AUTH_REQUIRED=true, where the tenant is derived from the signed-in
# session and this header is IGNORED — so for production you set VITE_API_URL and sign in,
# and VITE_TENANT_ID is a no-op. Leave it unset in a production console deploy.
# VITE_TENANT_ID=00000000-0000-0000-0000-000000000000
